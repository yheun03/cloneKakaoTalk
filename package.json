{
  "name": "cloneKakaoTalk",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20 <23"
  },
  "browserslist": [
    "defaults and supports es6-module",
    "not dead",
    "not op_mini all"
  ],
  "scripts": {
    "build": "vite build",
    "build:clean": "npm run clean && vite build",
    "clean": "rm -rf dist node_modules/.vite node_modules/.cache",
    "dev": "vite --host 0.0.0.0",
    "dev:host": "vite --host 0.0.0.0 --port 8080",
    "dev:root": "VITE_APP_BASE_URL=/ vite --host 0.0.0.0",
    "dev:clean": "npm run clean && vite --host 0.0.0.0",
    "dev:clean:host": "npm run clean && vite --host 0.0.0.0 --port 8080",
    "dev:clean:root": "npm run clean && VITE_APP_BASE_URL=/ vite --host 0.0.0.0",
    "deploy": "npm run build && cp dist/index.html dist/404.html && gh-pages -d dist -b gh-pages -f --nojekyll",
    "preview": "vite preview --host 0.0.0.0",
    "preview:host": "vite preview --host 0.0.0.0 --port 8080",
    "preview:clean": "npm run build:clean && vite preview --host 0.0.0.0",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore"
  },
  "dependencies": {
    "@vuepic/vue-datepicker": "^11.0.2",
    "holiday-kr": "^0.1.5",
    "vue": "^3.5.12",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/eslint-config-prettier": "^9.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.19.2",
    "gh-pages": "^6.3.0",
    "sass": "^1.80.4",
    "vite": "^6.0.0",
    "vite-svg-loader": "^4.0.0"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true,
      "es2022": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended",
      "@vue/eslint-config-prettier"
    ],
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    },
    "rules": {}
  }
}
